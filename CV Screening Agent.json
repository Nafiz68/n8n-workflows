        "jsCode": "return items.map(item => {\n  // Get the AI output\n  const questions = item.json.output;\n\n  // Replace actual line breaks with a single space or \\n for Google Sheets\n  const formatted = questions.replace(/\\n/g, \" | \"); // You can use \" ; \" or \"\\n\" if Google Sheets supports it\n\n  return {\n    json: {\n      Questions: formatted\n    }\n  };\n});"
