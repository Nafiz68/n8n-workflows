{
  "name": "Latest Music Feed",
  "nodes": [
    {
      "parameters": {
        "content": "Every morning, it keeps an ear out for fresh drops from your favorite artists. The moment something new hits, it crafts a hype message and delivers it straight to Telegram, so you’re always first to know and never miss the vibe 🎧🔥\n",
        "height": 144,
        "width": 400
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -80,
        -288
      ],
      "id": "94001222-8d3e-4446-8c98-0bc036a18a84",
      "name": "Sticky Note"
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "months",
              "triggerAtHour": 9
            }
          ]
        }
      },
