      ],
      "id": "8be860fa-ca94-473b-9056-0dd707aa8fc3",
      "name": "If"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=A new music release has been detected!\n\nArtist: {{ $json.artist }}\nAlbum/Single: {{ $json.albumName }}\nLink: {{ $json.albumUrl }}\n\nWrite a short exciting Telegram notification announcing this new release. Use the EXACT artist name provided above. Use HTML formatting with <b> for bold and <a href=\"URL\">text</a> for links. Include relevant music emojis. Max 80 words. No markdown.",
        "options": {
          "systemMessage": "You are an enthusiastic music news reporter. Keep announcements hype, fun and short."
        }
      },
