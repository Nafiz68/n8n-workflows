      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "jsCode": "const artists = [\n  { name: \"Travis Scott\" },\n  { name: \"Dua Lipa\" },\n  { name: \"The Weeknd\" },\n  { name: \"Billie Eilish\" },\n  { name: \"Fetty Wap\" }\n];\n\nreturn artists.map(a => ({ json: a }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -336,
        12
      ],
      "id": "d3243df6-1a48-4a9d-8368-ab041a282574",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "url": "=https://ws.audioscrobbler.com/2.0/?method=artist.getTopAlbums&artist={{ $json.name }}&api_key=YOUR_API_KEY&format=json&limit=1",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        112,
        -112
      ],
      "id": "1b58cbbb-c5c1-47f0-be46-e5a0fc8c8e69",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const artist = $input.first().json.topalbums?.['@attr']?.artist;\nconst albums = $input.first().json.topalbums?.album || [];\n\nif (albums.length === 0) {\n  return [{ json: { isNew: false, artist } }];\n}\n\nconst latest = albums[0];\n\nreturn [{\n  json: {\n    isNew: true,\n    artist,\n    albumName: latest.name,\n    albumUrl: latest.url,\n    albumImage: latest.image?.[2]?.['#text'] || ''\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        336,
        -112
      ],
      "id": "22f6ef66-518b-468f-8764-e89a2564fb25",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "370d9ea2-2839-48ac-a5de-3a8bdc0ceea8",
              "leftValue": "={{ $json.isNew }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
