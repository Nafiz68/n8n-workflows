        "sendTo": "YOUR_MAIL",
        "subject": "💰 Your Weekly Finance Report",
        "message": "=<div style=\"font-family: Arial, sans-serif; max-width: 560px; margin: auto; padding: 32px; background: #f4fbf4; border-radius: 12px; border: 1px solid #c0e0c0;\">\n\n  <p style=\"font-size: 13px; color: #3a7a3a; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 24px;\">\n    💰 Weekly Finance Summary\n  </p>\n\n  <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 24px;\">\n    <tr style=\"background: #e0f0e0;\">\n      <td style=\"padding: 10px 14px; font-weight: bold; color: #2d5a2d;\">Total Income</td>\n      <td style=\"padding: 10px 14px; color: #2d5a2d;\">৳{{ $('Code in JavaScript').item.json.totalIncome }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding: 10px 14px; font-weight: bold; color: #7a2d2d;\">Total Expenses</td>\n      <td style=\"padding: 10px 14px; color: #7a2d2d;\">৳{{ $('Code in JavaScript').item.json.totalExpense }}</td>\n    </tr>\n    <tr style=\"background: #e0f0e0;\">\n      <td style=\"padding: 10px 14px; font-weight: bold;\">Balance</td>\n      <td style=\"padding: 10px 14px;\">৳{{ $('Code in JavaScript').item.json.balance }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding: 10px 14px; font-weight: bold;\">Savings Rate</td>\n      <td style=\"padding: 10px 14px;\">{{ $('Code in JavaScript').item.json.savingsRate }}%</td>\n    </tr>\n    <tr style=\"background: #e0f0e0;\">\n      <td style=\"padding: 10px 14px; font-weight: bold;\">Top Categories</td>\n      <td style=\"padding: 10px 14px;\">{{ $('Code in JavaScript').item.json.topCategories }}</td>\n    </tr>\n  </table>\n\n  <p style=\"font-size: 13px; color: #3a7a3a; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 12px;\">\n    💡 AI Tips For You\n  </p>\n\n  <div style=\"font-size: 15px; line-height: 1.8; color: #2c3d2c; white-space: pre-line;\">\n    {{ $json.output }}\n  </div>\n\n  <hr style=\"border: none; border-top: 1px solid #c0e0c0; margin: 28px 0;\">\n  <p style=\"font-size: 12px; color: #6a9a6a; text-align: right;\">Auto-generated every Monday morning 📊</p>\n\n</div>",
