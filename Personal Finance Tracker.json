    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nlet totalIncome = 0;\nlet totalExpense = 0;\nconst categoryTotals = {};\n\nfor (const row of rows) {\n  const type = row.json.Type?.toLowerCase();\n  const amount = parseFloat(row.json.Amount) || 0;\n  const category = row.json.Category || \"Uncategorized\";\n\n  if (type === \"income\") {\n    totalIncome += amount;\n  } else if (type === \"expense\") {\n    totalExpense += amount;\n    categoryTotals[category] = (categoryTotals[category] || 0) + amount;\n  }\n}\n\nconst balance = totalIncome - totalExpense;\n\n// Sort categories by spend\nconst topCategories = Object.entries(categoryTotals)\n  .sort((a, b) => b[1] - a[1])\n  .map(([cat, amt]) => `${cat}: ৳${amt}`)\n  .join(\", \");\n\nreturn [{\n  json: {\n    totalIncome,\n    totalExpense,\n    balance,\n    topCategories,\n    savingsRate: totalIncome > 0 ? ((balance / totalIncome) * 100).toFixed(1) : 0\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ],
      "id": "6d6670b3-f870-4b42-9491-90f812557e9c",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a friendly personal finance advisor. Based on this weekly summary, give 3 short and practical money tips. Keep it conversational, not preachy.\n\nIncome: ৳{{ $('Code in JavaScript').item.json.totalIncome }}\nExpenses: ৳{{ $('Code in JavaScript').item.json.totalExpense }}\nBalance: ৳{{ $('Code in JavaScript').item.json.balance }}\nSavings Rate: {{ $('Code in JavaScript').item.json.savingsRate }}%\nTop Spending Categories: {{ $('Code in JavaScript').item.json.topCategories }}\n\nFormat: just 3 bullet points, no intro, no outro.",
        "options": {}
