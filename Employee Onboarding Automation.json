    {
      "parameters": {
        "promptType": "define",
        "text": "=Write a warm and professional employee onboarding welcome email for:\\n\\nName: {{ $('Code').item.json.name }}\\nRole: {{ $('Code').item.json.role }}\\nDepartment: {{ $('Code').item.json.department }}\\nStart Date: {{ $('Code').item.json.startDate }}\\nManager: {{ $('Code').item.json.manager }}\\nEquipment Ready: {{ $('Code').item.json.equipment }}\\n\\nRules:\\n- Warm but professional tone\\n- Mention their role and department\\n- Tell them their manager will greet them\\n- Mention their equipment is ready\\n- 3 short paragraphs\\n- No subject line, just the body\\n- End with 'Welcome aboard!",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        448,
        176
      ],
      "id": "44fb1c01-f5c4-4a53-b46a-00c343368fd0",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "jsCode": "const emp = $input.first().json;\n\n// Clean up name for Trello board\nconst boardName = `🚀 Onboarding - ${emp.Name}`;\n\n// Format start date nicely\nconst startDate = new Date(emp.StartDate);\nconst formattedDate = startDate.toLocaleDateString('en-US', {\n  weekday: 'long',\n  year: 'numeric',\n  month: 'long',\n  day: 'numeric'\n});\n\n// Calculate due dates\nconst day3 = new Date(startDate);\nday3.setDate(day3.getDate() + 3);\n\nconst day7 = new Date(startDate);\nday7.setDate(day7.getDate() + 7);\n\nconst day30 = new Date(startDate);\nday30.setDate(day30.getDate() + 30);\n\nreturn [{\n  json: {\n    name: emp.Name,\n    email: emp.Email,\n    role: emp.Role,\n    department: emp.Department,\n    startDate: formattedDate,\n    manager: emp.Manager,\n    equipment: emp.Equipment,\n    boardName,\n    due3: day3.toISOString(),\n    due7: day7.toISOString(),\n    due30: day30.toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        176
      ],
      "id": "087c2aff-97d0-4986-800e-d2e06162c0f3",
      "name": "Code"
    },
