      "parameters": {
        "sendTo": "={{ $('Code').item.json.email }}",
        "subject": "=🎉 Welcome to the Team, {{ $('Code').item.json.name }}!",
        "message": "=<div style=\"font-family: Arial, sans-serif; max-width: 560px; margin: auto; padding: 32px; background: #f0f4ff; border-radius: 12px; border: 1px solid #c0ccf0;\">    <p style=\"font-size: 13px; color: #3a4a9a; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 24px;\">     🎉 Welcome to the Team!   </p>    <div style=\"font-size: 16px; line-height: 1.9; color: #2c2c3d; white-space: pre-line;\">     {{ $json.choices[0].message.content }}   </div>    <hr style=\"border: none; border-top: 1px solid #c0ccf0; margin: 28px 0;\">    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 20px;\">     <tr style=\"background: #dde4ff;\">       <td style=\"padding: 10px 14px; font-weight: bold; color: #3a4a9a;\">Role</td>       <td style=\"padding: 10px 14px;\">{{ $('Code').item.json.role }}</td>     </tr>     <tr>       <td style=\"padding: 10px 14px; font-weight: bold; color: #3a4a9a;\">Department</td>       <td style=\"padding: 10px 14px;\">{{ $('Code').item.json.department }}</td>     </tr>     <tr style=\"background: #dde4ff;\">       <td style=\"padding: 10px 14px; font-weight: bold; color: #3a4a9a;\">Start Date</td>       <td style=\"padding: 10px 14px;\">{{ $('Code').item.json.startDate }}</td>     </tr>     <tr>       <td style=\"padding: 10px 14px; font-weight: bold; color: #3a4a9a;\">Manager</td>       <td style=\"padding: 10px 14px;\">{{ $('Code').item.json.manager }}</td>     </tr>     <tr style=\"background: #dde4ff;\">       <td style=\"padding: 10px 14px; font-weight: bold; color: #3a4a9a;\">Equipment</td>       <td style=\"padding: 10px 14px;\">{{ $('Code').item.json.equipment }}</td>     </tr>   </table>    <p style=\"font-size: 12px; color: #6a7ab8; text-align: right;\">     Sent by HR Automation System ✨   </p>  </div>",
        "options": {
          "appendAttribution": false
