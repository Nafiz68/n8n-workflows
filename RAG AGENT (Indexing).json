    {
      "parameters": {
        "jsCode": "const text = $input.item.json.text;\nconst chunkSize = 500;\nconst overlap = 50;\nconst chunks = [];\n\nfor (let i = 0; i < text.length; i += chunkSize - overlap) {\n  chunks.push({\n    json: {\n      chunk: text.slice(i, i + chunkSize),\n      chunkIndex: chunks.length,\n      source: $input.item.json.info?.Title ?? $input.item.json.info?.Subject ?? 'unknown'\n    }\n  });\n}\n\nreturn chunks;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
