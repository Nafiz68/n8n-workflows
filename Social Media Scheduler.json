        "jsCode": "const raw = $input.first().json.output;\n\n// Strip any accidental markdown fences\nconst cleaned = raw.replace(/```json|```/g, '').trim();\n\nconst posts = JSON.parse(cleaned);\n\nreturn posts.map(post => ({ json: post }));"
