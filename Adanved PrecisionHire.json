      "parameters": {
        "promptType": "define",
        "text": "=You are a strict CV screening system for a Software Engineer position.\n\nYour task is to evaluate how well the candidate matches this role.\n\nReturn ONLY a number between 0 and 100.\n\nRules:\n- Output ONLY the number\n- No explanation\n- No text\n- No symbols\n- No JSON\n\nEvaluation Criteria:\n1. Programming skills (especially relevant languages like Python, JavaScript, Java, C++) – 30%\n2. Frameworks & technologies (e.g., React, Node.js, databases, backend systems) – 25%\n3. Projects & real-world experience (production apps, scalability, complexity) – 25%\n4. Computer Science fundamentals (algorithms, systems, problem solving) – 10%\n5. Education & achievements – 10%\n\nScoring Guide:\n- 90–100: Excellent Software Engineer candidate (job-ready)\n- 75–89: Strong candidate\n- 60–74: (average, may need training)\n- Below 60: Weak fit\n\nNow evaluate this CV:\n\n{{ $json.text }}",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        448,
        -672
      ],
      "id": "f9928e27-4570-4832-b186-a0ab9a4da305",
