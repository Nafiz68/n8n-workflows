    {
      "parameters": {
        "jsCode": "// return items.map(item => {\n//   // Get the AI output\n//   const questions = item.json.output;\n\n//   // Replace actual line breaks with a single space or \\n for Google Sheets\n//   const formatted = questions.replace(/\\n/g, \" | \"); // You can use \" ; \" or \"\\n\" if Google Sheets supports it\n\n//   return {\n//     json: {\n//       Questions: formatted\n//     }\n//   };\n// });\n\nreturn items.map(item => {\n  const questions = item.json.output;\n  const formatted = questions.replace(/\\n/g, \" | \");\n\n  const qArray = questions.split('\\n')\n    .map(q => q.replace(/^\\d+\\.\\s*/, '').trim())\n    .filter(q => q.length > 0);\n\n  const candidateId = 'CAND-' + Date.now() + '-' + Math.random().toString(36).substr(2, 6).toUpperCase();\n\n  return {\n    json: {\n      Questions: formatted,\n      candidateId,\n      q1: qArray[0] || \"\",\n      q2: qArray[1] || \"\",\n      q3: qArray[2] || \"\",\n      q4: qArray[3] || \"\",\n      q5: qArray[4] || \"\",\n      name: $('On form submission').item.json.NAME,\n      email: $('On form submission').item.json.EMAIL,\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
