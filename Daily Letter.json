        "message": "=<div style=\"font-family: Georgia, serif; max-width: 520px; margin: auto; padding: 32px; background: #fffaf4; border-radius: 12px; border: 1px solid #f0d9c0;\">\n\n  <p style=\"font-size: 13px; color: #c4845a; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 24px;\">\n    💌 A little note for you\n  </p>\n\n  <div style=\"font-size: 16px; line-height: 1.9; color: #3d2c2c; white-space: pre-line;\">\n    {{ $json.output }}\n  </div>\n\n  <hr style=\"border: none; border-top: 1px solid #f0d9c0; margin: 28px 0;\">\n\n  <p style=\"font-size: 12px; color: #b8967a; text-align: right;\">\n    Sent with love, every single day ✨\n  </p>\n\n</div>",
