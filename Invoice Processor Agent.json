        "text": "={{ $json.text }}",
        "options": {
          "systemMessage": "You are an invoice data extraction assistant. \nExtract key fields from the invoice text provided.\n\nReturn ONLY a valid JSON object. No explanation, no markdown, no code fences. Just raw JSON like this:\n\n{\n  \"vendor_name\": \"Company or person who issued the invoice\",\n  \"invoice_number\": \"Invoice ID or number, or null if not found\",\n  \"invoice_date\": \"Date of invoice in YYYY-MM-DD format, or null if not found\",\n  \"due_date\": \"Payment due date in YYYY-MM-DD format, or null if not found\",\n  \"amount_due\": \"Total amount due as a number only, no currency symbols\",\n  \"currency\": \"Currency code e.g. USD ($), EUR, BDT, or null if not found\",\n  \"line_items_summary\": \"One sentence summary of what was purchased or billed\",\n  \"status\": \"Unpaid\"\n}\n\nRules:\n- Never guess or hallucinate values\n- If a field is not found, return null\n- Amount must be numeric only e.g. 1500.00\n- Due date can be cound in Terms"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        672,
        0
      ],
      "id": "ad366095-8f1f-4ebc-9b4b-5ed4b00d62e1",
