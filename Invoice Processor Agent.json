    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.output;\n\nconst cleaned = raw.replace(/```json|```/g, '').trim();\n\nconst invoice = JSON.parse(cleaned);\n\n// Attach original filename from Drive trigger\ninvoice.file_name = $('Google Drive Trigger').first().json.name;\ninvoice.uploaded_at = new Date().toISOString().split('T')[0];\n\nreturn [{ json: invoice }];"
      },
