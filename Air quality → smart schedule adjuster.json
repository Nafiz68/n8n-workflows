    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a helpful air quality assistant for Dhaka. When air quality is bad, you warn users about outdoor activities in a friendly, concise way.\n\nAir quality in Dhaka today: {{ $('Code').first().json.aqiEmoji }} {{ $('Code').first().json.aqiLabel }} ({{ $('Code').first().json.aqiParam }}: {{ $('Code').first().json.aqiValue }} µg/m³)\n\nMy events today:\n{{ $('Get many events').all().map((e,i) => `${i+1}. ${e.json.summary} (${e.json.start?.dateTime || e.json.start?.date || 'all day'})`).join('\\n') }}\n\nIdentify which events are outdoor or physical (walks, sports, runs, commutes, outdoor meetings). Ignore indoor events (calls, work, study). Write a short friendly Telegram warning under 100 words using simple HTML with <b> for bold. No markdown.",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
