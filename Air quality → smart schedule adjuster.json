        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        848,
        144
      ],
      "id": "3c1baa0d-8bf7-4c3e-ad41-6d75fa4c3aac",
      "name": "Groq Chat Model",
      "credentials": {
        "groqApi": {
          "id": "YOUR_GROQ_CREDENTIALS",
          "name": "Groq account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const aqData = $input.first().json;\nconst results = aqData.results || [];\n\n// Find PM2.5 by sensor ID\nconst pm25 = results.find(r => r.sensorsId === 15403598);\n\nif (!pm25) {\n  return [{ json: { shouldAlert: false, reason: 'No PM2.5 data found' } }];\n}\n\nconst aqiValue = pm25.value;\nconst aqiParam = 'PM2.5';\n\nlet aqiLabel, aqiEmoji, isBad;\n\nif (aqiValue <= 12)       { aqiLabel = 'Good';                            aqiEmoji = '🟢'; isBad = false; }\nelse if (aqiValue <= 35)  { aqiLabel = 'Moderate';                        aqiEmoji = '🟡'; isBad = false; }\nelse if (aqiValue <= 55)  { aqiLabel = 'Unhealthy for Sensitive Groups';  aqiEmoji = '🟠'; isBad = true; }\nelse if (aqiValue <= 150) { aqiLabel = 'Unhealthy';                       aqiEmoji = '🔴'; isBad = true; }\nelse if (aqiValue <= 250) { aqiLabel = 'Very Unhealthy';                  aqiEmoji = '🟣'; isBad = true; }\nelse                      { aqiLabel = 'Hazardous';                       aqiEmoji = '⚫'; isBad = true; }\n\nconst today = new Date().toLocaleDateString('en-GB', {\n  day: '2-digit', month: 'short', year: 'numeric'\n});\n\nreturn [{ json: { shouldAlert: isBad, aqiValue, aqiParam, aqiLabel, aqiEmoji, today } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        -160
      ],
      "id": "072d3f7c-617e-4b79-b627-0ce75e74a72f",
      "name": "Code"
    },
    {
      "parameters": {
        "jsCode": "const agentReply = $input.first().json.output;\nconst { aqiEmoji, aqiLabel, aqiValue, aqiParam, today } = $('Code').first().json;\n\nconst message = `🌫️ <b>Air Quality Alert — ${today}</b>\\n\\n` +\n                `${aqiEmoji} <b>${aqiLabel}</b> (${aqiParam}: ${aqiValue} µg/m³)\\n\\n` +\n                `${agentReply}`;\n\nreturn [{ json: { message } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1248,
        -48
      ],
