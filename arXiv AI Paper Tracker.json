      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const xml = $input.first().json.data;\n\nconst items = [];\nconst entries = xml.match(/<entry>([\\s\\S]*?)<\\/entry>/g) || [];\n\nfor (const entry of entries) {\n  const title = entry.match(/<title>([\\s\\S]*?)<\\/title>/)?.[1]?.trim() || \"No title\";\n  \n  const link = entry.match(/<id>([\\s\\S]*?)<\\/id>/)?.[1]?.trim() || \"No link\";\n  \n  const abstract = entry.match(/<summary>([\\s\\S]*?)<\\/summary>/)?.[1]?.trim().replace(/\\s+/g, ' ') || \"No abstract\";\n  \n  const authorMatches = [...entry.matchAll(/<name>([\\s\\S]*?)<\\/name>/g)];\n  const authors = authorMatches.map(m => m[1].trim()).slice(0, 3).join(', ');\n\n  items.push({ json: { title, link, abstract, authors } });\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        124
      ],
      "id": "1d305ee7-811e-42c3-9358-8abb5aee3a19",
