    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\nconst title = $('Loop Over Items').item.json.title;\nconst authors = $('Loop Over Items').item.json.authors;\nconst link = $('Loop Over Items').item.json.link;\n\nconst summaryMatch = output.match(/SUMMARY:\\s*([\\s\\S]*?)(?=SCORE:|$)/i);\nconst scoreMatch = output.match(/SCORE:\\s*(\\d+)/i);\n\nconst summary = summaryMatch?.[1]?.trim() || \"No summary\";\nconst score = scoreMatch?.[1] || \"0\";\n\nreturn [{ json: { title, authors, link, summary, score } }];"
      },
