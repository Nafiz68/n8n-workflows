    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a research assistant. Given a paper title and abstract, respond in exactly this format:\nSUMMARY: (2 sentences max, plain English)\nSCORE: (1-10 based on novelty and practical AI impact, just the number)\n\n={{ 'Title: ' + $json.title + '\\n\\nAbstract: ' + $json.abstract }}\n",
